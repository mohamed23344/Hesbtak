generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkflowSession {
  id             String   @id @default(uuid())

  organizationId String

  currentStep    String

  status         String

  payload        Json

  createdBy      String

  createdAt      DateTime @default(now())

  updatedAt      DateTime @updatedAt

  @@map("workflow_sessions")
}