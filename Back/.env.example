# App
PORT=3000
APP_PORT=3000
NODE_ENV=development

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hesbtk
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hesbtk

# Redis, reserved for future queues/cache
REDIS_PASSWORD=redis
REDIS_PORT=6379
REDIS_URL=redis://:redis@localhost:6379

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
# OAuth 2.0 web client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=151245733785-fmqeg8qo1ecrh4e5sko4ud2g32imthtq.apps.googleusercontent.com

# Gmail SMTP for OTP emails. Use a Google app password, not your normal password.
GOOGLE_EMAIL=
GOOGLE_APP_PASSWORD=
# Set to false only for local machines where Node reports SELF_SIGNED_CERT_IN_CHAIN.
GOOGLE_SMTP_REJECT_UNAUTHORIZED=true
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3000

# Paymob Unified Checkout
# Create these values in your Paymob dashboard. Never expose the secret key to the frontend.
PAYMOB_SECRET_KEY="graduation_project"
PAYMOB_PUBLIC_KEY=
PAYMOB_HMAC_SECRET="gradProjectSecretKey"
# Comma-separated Paymob payment method/integration IDs enabled for checkout.
PAYMOB_PAYMENT_METHOD_IDS=
PAYMOB_API_URL=https://accept.paymob.com
# BACKEND_URL must be a public HTTPS URL in Paymob testing/production.
# Paymob cannot send callbacks to localhost. For local testing use a tunnel such as ngrok.

# AI assistant
GROQ_API_KEY=
# Use "mock" for local deterministic embeddings or "huggingface" for hosted embeddings.
AI_EMBEDDING_PROVIDER=mock
HF_TOKEN=
HF_EMBEDDING_MODEL=BAAI/bge-m3
